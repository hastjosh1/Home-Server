# ============================================================
# Home Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git! It contains your secrets.
# ============================================================

# Your server's local IP address on your home network
# Find it by running: hostname -I | awk '{print $1}'
SERVER_IP=192.168.1.x

# Timezone (find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Etc/UTC

# User/Group ID for file permissions (usually 1000 for the first user)
# Find yours by running: id
PUID=1000
PGID=1000

# ---- DuckDNS ----
# Get these from https://www.duckdns.org after creating a free account
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token-here

# ---- Homarr ----
# Generate a random 64-character hex key by running:
#   openssl rand -hex 32
HOMARR_SECRET_KEY=generate-a-random-key-here

# ---- Pi-hole ----
# Leave empty to disable the login password (recommended for home use)
# Set to a password string to require login
PIHOLE_PASSWORD=
